# ---- app ----
NEXT_PUBLIC_BASE_URL=https://dhomniroute.dpdns.org

# ---- litefs / instance identity ----
INSTANCE_NAME=omniroute-node-1
INSTANCE_ADDR=omniroute-node-1
# nếu multi-node cross-host thì đặt bằng IP nội bộ/VPN/Tailscale reachable
# ví dụ:
# INSTANCE_ADDR=100.64.0.12

# ---- consul ----
CONSUL_HTTP_ADDR=http://consul:8500
# fallback nhiều consul endpoint (ip/dns động), ngăn cách bằng dấu phẩy
# ví dụ: CONSUL_CANDIDATES=consul-a.tailnet.ts.net,consul-b.tailnet.ts.net,consul-c.tailnet.ts.net
CONSUL_CANDIDATES=

# ---- app secrets cũ ----
JWT_SECRET=
API_KEY_SECRET=
MACHINE_ID_SALT=
STORAGE_ENCRYPTION_KEY=
INITIAL_PASSWORD=

# ---- cloudflared / app vars cũ khác ----
OMNIROUTE_PORT=20128


# ---- tailscale (optional, ưu tiên khi IP động) ----
# Nếu có DNS MagicDNS ổn định, set thẳng TS_DNS_NAME và dùng cho INSTANCE_ADDR.
# ví dụ:
# TS_DNS_NAME=omniroute-node-1.yourtailnet.ts.net
TS_DNS_NAME=

# Nếu muốn tự ghép DNS: <TS_NODE_NAME>.<TAILSCALE_TAILNET>
# ví dụ:
# TS_NODE_NAME=omniroute-node-1
# TAILSCALE_TAILNET=yourtailnet.ts.net
TS_NODE_NAME=
TAILSCALE_TAILNET=
